server {
    listen       ${PORT};
    server_name  _;

    root   /usr/share/nginx/html;
    index  index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Long cache for the immutable static asset
    location = /index.html {
        add_header Cache-Control "public, max-age=300, must-revalidate";
    }
}
